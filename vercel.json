{
  "version": 2,
  "builds": [
    {
      "src": "ldey/backend/app.py",
      "use": "@vercel/python"
    },
    {
      "src": "New_ldey/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/ldey/backend/app.py"
    },
    {
      "src": "/(.*)",
      "dest": "/New_ldey/$1"
    }
  ]
}